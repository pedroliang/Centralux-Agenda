# Copie este arquivo como .env.local e preencha com os dados do seu deploy Vercel.
# A URL é onde estão hospedadas as funções serverless (api/) que conversam com o Neon.
# Em dev rodando `vercel dev` (ou hospedando o front e o backend juntos no Vercel),
# pode deixar VAZIO — o cliente assume "/api".
VITE_API_URL=https://SEU-PROJETO.vercel.app/api

# ===== Variáveis usadas SOMENTE pelo backend (Vercel Functions) =====
# NÃO comece com VITE_ — assim ela nunca vaza para o bundle do navegador.
# Configure no painel do Vercel em "Settings -> Environment Variables".
# DATABASE_URL=postgresql://USUARIO:SENHA@HOST.neon.tech/neondb?sslmode=require
